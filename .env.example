# Copy to .env and fill in your keys ( .env is gitignored )
# cp .env.example .env

# --- OpenAI (default for L0; model gpt-4o-mini / gpt-4o) ---
OPENAI_API_KEY=sk-...
# Optional:
# OPENAI_ORG=org-...

# --- Anthropic (if using Claude models) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Cohere (if using command-r*) ---
# COHERE_API_KEY=...

# --- Together (if using Mixtral / Llama) ---
# TOGETHER_API_KEY=...

# --- Google Vertex (if using Gemini via Vertex) ---
# GCP_PROJECT=your-project-id
# GCP_LOCATION=us-central1

# --- Local vLLM / OpenAI-compatible server ---
# LOCAL_LLM_PORT=8000

# --- SafeConfirm overrides (optional) ---
# SAFECONFIRM_MODE=log_only
# SAFECONFIRM_POLICY=rule_v1
# SAFECONFIRM_CONFIG_PATH=safeconfirm/config/defaults.yaml
